WITH customer_base AS (
  SELECT 
    customer_id, 
    EXTRACT(YEAR FROM MIN(order_date)) AS cohort_year,
    MIN(order_date) AS first_purchase_date
  FROM `enter.tablename_123456.events_*`
  GROUP BY 1
),
late_spending_vertical AS (
  SELECT 
    b.cohort_year,
    EXTRACT(YEAR FROM t.order_date) AS spend_calendar_year,
    -- Count distinct "Late" customers for that specific year
    COUNT(DISTINCT IF(DATE_DIFF(t.order_date, b.first_purchase_date, DAY) > 365, t.customer_id, NULL)) AS late_customers,
    -- Sum "Late" profit for that specific year
    SUM(IF(DATE_DIFF(t.order_date, b.first_purchase_date, DAY) > 365, t.profit, 0)) AS late_profit
  FROM customer_base b
  JOIN `enter.tablename_123456.events_*` t ON t.customer_id = b.customer_id
  GROUP BY 1, 2
)

SELECT 
  cohort_year,
  spend_calendar_year,
  late_customers,
  ROUND(late_profit, 0) AS late_profit,
  -- Efficiency Metric: How much is each "Old" customer worth this year?
  ROUND(SAFE_DIVIDE(late_profit, late_customers), 2) AS profit_per_resurrected_customer
FROM late_spending_vertical
WHERE late_profit > 0
ORDER BY cohort_year DESC, spend_calendar_year ASC;
