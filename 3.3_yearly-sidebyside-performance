WITH customer_base AS (
  SELECT 
    customer_id, 
    EXTRACT(YEAR FROM MIN(order_date)) AS cohort_year,
    MIN(order_date) AS first_purchase_date,
    DATE_DIFF(CURRENT_DATE(), MIN(order_date), DAY) AS account_age_days
  FROM `enter.tablename_123456.events_*`
  GROUP BY 1
),
cohort_1yr_performance AS (
  SELECT 
    b.cohort_year,
    b.customer_id,
    b.account_age_days,
    SUM(t.profit) AS prof_1yr
  FROM customer_base b
  LEFT JOIN `enter.tablename_123456.events_*` t 
    ON t.customer_id = b.customer_id
    AND DATE_DIFF(t.order_date, b.first_purchase_date, DAY) <= 365
  GROUP BY 1, 2, 3
)

SELECT 
  cohort_year,
  COUNT(customer_id) AS total_customers,
  -- Status tells us if the data is "Finished" or "In Progress"
  CASE 
    WHEN MIN(account_age_days) >= 365 THEN 'Matured (Full Year Data)'
    ELSE 'In-Progress (Partial Year)'
  END AS cohort_status,
  ROUND(AVG(prof_1yr), 2) AS avg_ltv_year_1,
  APPROX_QUANTILES(prof_1yr, 2)[OFFSET(1)] AS median_ltv_year_1,
  ROUND(SUM(prof_1yr), 0) AS total_profit_generated_yr1
FROM cohort_1yr_performance
GROUP BY 1
ORDER BY 1;
